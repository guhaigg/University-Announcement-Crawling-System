{
  "name": "university-announcement-crawler",
  "version": "1.0.0",
  "description": "高校研招公告工作台：支持智能导航、公告正文抓取、调剂清洗与 Markdown 归档",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js && node --check public/app.js",
    "postcheck": "npm run readme:update",
    "review": "npm run check",
    "readme:update": "node scripts/update-readme.js",
    "mysql:start": "powershell -ExecutionPolicy Bypass -File scripts/mysql-start.ps1",
    "mysql:stop": "powershell -ExecutionPolicy Bypass -File scripts/mysql-stop.ps1",
    "mysql:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/mysql-bootstrap.ps1"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cheerio": "^1.0.0",
    "express": "^4.21.2",
    "iconv-lite": "^0.6.3",
    "mysql2": "^3.14.5",
    "node-cron": "^3.0.3"
  }
}
